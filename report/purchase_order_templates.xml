<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_purchase_order_import">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <style>
                        .table-bordered { 
                            border: 2px solid black !important; 
                            border-collapse: collapse; 
                            width: 100%; 
                        }
                        .table-bordered th, .table-bordered td { 
                            border: 1px solid black !important; 
                            padding: 8px 10px; 
                            vertical-align: middle; 
                        }
                        .header-title { 
                            background-color: #000; 
                            color: #fff; 
                            padding: 10px; 
                            text-align: center; 
                            font-weight: bold; 
                            font-size: 16px; 
                        }
                        .section-header { 
                            background-color: #e8e8e8; 
                            font-weight: bold; 
                            text-align: center; 
                            padding: 10px;
                            border-bottom: 1px solid black; 
                        }
                        .info-box {
                            border: 2px solid black;
                            padding: 6px;
                            margin-top: -2px;
                        }
                        body {
                            margin: 0;
                            padding: 0;
                        }
                    </style>

                    <div class="header">
                        <table style="width: 100%; border: 2px solid black; border-collapse: collapse;">
                            <tr>
                                <td style="width: 40%; border-right: 1px solid black; padding: 15px; vertical-align: middle;">
                                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)" style="max-height: 60px;" alt="Logo"/>
                                </td>
                                <td style="width: 60%; padding: 0; vertical-align: top;">
                                    <div class="header-title">PURCHASE ORDER</div>
                                    <div style="padding: 10px; text-align: right;">
                                        <strong>PO No: </strong> <span t-field="o.name"/><br/>
                                        <strong>Date: </strong> <span t-field="o.date_order" t-options='{"widget": "date", "format": "dd.MM.yyyy"}'/>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <div class="page" style="font-family: 'Arial', sans-serif; font-size: 12px; line-height: 1.6; color: #333;">

                        <!-- Buyer/Supplier Section -->
                        <table class="table-bordered" style="margin-top: -2px;">
                            <tr>
                                <th class="section-header" style="width: 50%;">Buyer</th>
                                <th class="section-header" style="width: 50%;">Supplier</th>
                            </tr>
                            <tr>
                                <td style="padding: 12px;">
                                    <div style="margin-bottom: 8px;"><strong><span t-field="o.company_id.name"/></strong></div>
                                    <div style="margin-bottom: 4px;"><span t-field="o.company_id.street"/><t t-if="o.company_id.street2">, <span t-field="o.company_id.street2"/></t></div>
                                    <div style="margin-bottom: 8px;"><t t-if="o.company_id.city"><span t-field="o.company_id.city"/></t><t t-if="o.company_id.zip"> - <span t-field="o.company_id.zip"/></t></div>
                                    <div style="margin-bottom: 4px;"><strong>Phone No: </strong><span t-field="o.company_id.phone"/></div>
                                    <div style="margin-bottom: 4px;"><strong>STRN: </strong><span t-field="o.company_id.vat"/></div>
                                    <div style="margin-bottom: 4px;"><strong>NTN: </strong><span t-field="o.company_id.vat"/></div>
                                </td>
                                <td style="padding: 12px;">
                                    <div style="margin-bottom: 8px;"><strong><span t-field="o.partner_id.name"/></strong></div>
                                    <div style="margin-bottom: 4px;"><span t-field="o.partner_id.street"/><t t-if="o.partner_id.street2">, <span t-field="o.partner_id.street2"/></t></div>
                                    <div style="margin-bottom: 8px;"><t t-if="o.partner_id.city"><span t-field="o.partner_id.city"/></t><t t-if="o.partner_id.zip"> - <span t-field="o.partner_id.zip"/></t></div>
                                    <div style="margin-bottom: 4px;"><strong>Phone No: </strong><span t-field="o.partner_id.phone"/></div>
                                    <div style="margin-bottom: 4px;"><strong>NTN: </strong><span t-field="o.partner_id.vat"/></div>
                                    <div style="margin-bottom: 4px;"><strong>STRN: </strong><span t-field="o.partner_id.vat"/></div>
                                    <div style="margin-bottom: 4px;"><strong>CNIC: </strong><span t-field="o.partner_id.cnic"/></div>
                                    <div style="margin-bottom: 4px;"><strong>Payment Terms: </strong><span t-field="o.payment_term_id.name"/></div>
                                    <div style="margin-bottom: 4px;"><strong>Incoterms: </strong><span t-field="o.incoterm_id.code"/></div>
                                    <div style="margin-bottom: 4px;"><strong>Arrival Date: </strong><span t-field="o.date_planned" t-options='{"widget": "date", "format": "dd.MM.yyyy"}'/></div>
                                </td>
                            </tr>
                        </table>

                        <!-- Product Description Label -->
                        <div class="info-box" style="font-weight: bold;">
                            Product<br/>Description :
                        </div>

                        <!-- Items Table -->
                        <table class="table-bordered" style="margin-top: -2px;table-layout: fixed; ">
                            <thead>
                                <tr style="background-color: #e8e8e8;">
                                    <th style="text-align: center; width: 4%;">Sr#</th>
                                    <th style="text-align: center; width: 35%;">Item Description</th>
                                    <th style="text-align: center; width: 5%;">UoM</th>
                                    <th style="text-align: center; width: 8%;">QTY</th>
                                    <th style="text-align: center; width: 9%;">Delivery Date</th>
                                    <th style="text-align: center; width: 9%;">Rate</th>
                                    <th style="text-align: center; width: 12%;">Net Amount</th>
                                    <th style="text-align: center; width: 8%;">ALT UOM</th>
                                    <th style="text-align: center; width: 10%;">ALT UOM QTY</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.order_line" t-as="line">
                                    <tr>
                                        <td style="text-align: center;"><span t-esc="line_index + 1"/></td>
                                        <td style="word-wrap: break-word; overflow-wrap: break-word; white-space: normal; word-spacing: 2px; line-height: 1.8;"><span t-field="line.name"/></td>
                                        <td style="text-align: center;"><span t-field="line.product_uom.name"/></td>
                                        <td style="text-align: right;"><span t-esc="'{:,.3f}'.format(line.product_qty)"/></td>
                                        <td style="text-align: center;"><span t-field="line.date_planned" t-options='{"widget": "date", "format": "dd.MM.yyyy"}'/></td>
                                        <td style="text-align: right;"><span t-esc="'{:,.2f}'.format(line.price_unit)"/></td>
                                        <td style="text-align: right;"><span t-esc="'{:,.2f}'.format(line.price_subtotal)"/></td>
                                        <td style="text-align: center;"></td>
                                        <td style="text-align: center;"></td>
                                    </tr>
                                </t>
                                <!-- Total Row -->
                                <tr>
                                    <td colspan="2"><strong>Total</strong></td>
                                    <td></td>
                                    <td style="text-align: right;"><strong><span t-esc="'{:,.3f}'.format(sum(o.order_line.mapped('product_qty')))"/></strong></td>
                                    <td colspan="2"></td>
                                    <td style="text-align: right;"><strong><span t-esc="'{:,.2f}'.format(o.amount_total)"/></strong></td>
                                    <td colspan="2"></td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- Amount in Words -->
                        <div class="info-box">
                            <span t-esc="o.currency_id.amount_to_text(o.amount_total).upper()"/>
                        </div>

                        <!-- Shipping Schedule Notice -->
                        <div class="info-box" style="font-weight: bold; text-transform: uppercase;">
                            FOR SHIPPING SCHEDULE PLEASE KEEP IN TOUCH WITH SUPPLY-CHAIN TEAM
                        </div>

                        <div style="margin-top: 20px; border:2px solid black; padding: 10px; font-size: 11px; line-height: 1.4;">
                            <div style="font-weight: bold; text-decoration: underline; margin-bottom: 5px;">Terms and Conditions:</div>
                            <div style="padding-left: 15px; font-family: 'Arial', sans-serif; font-size: 14px;">
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>1.</strong> Free days for every shipment must be at least 21 Days.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>2.</strong> This Purchase Order (PO) is subject to the terms and conditions incorporated herein after, which the vendor hereby agrees.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>3.</strong> PO number should be mentioned on all delivery orders, invoices &amp; other correspondence.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>4.</strong> Goods/Services should meet exact specifications, brands, country of origin and delivery dates as specified/agreed.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>5.</strong> Payments will be made subject to acceptance of goods.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>6.</strong> Supplier shall be responsible for handling and packaging of goods.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>7.</strong> Invalid/expired goods shall be returned without any payment or demand for replacement.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>8.</strong> Commercial invoice, certificate of analysis (COA) and delivery challan should be provided to us at the time of delivery of goods/services.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>9.</strong> Quantity and Description in Delivery Challan / Goods Receipt Challan (SRC) and in invoice including rate must be as per PO.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>10.</strong> All invoices will be subject to the approval of ABI.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>11.</strong> Delivery shall be as per dates mentioned in PO.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>12.</strong> All the Suppliers/Contractors/Service Providers shall comply with the ABI OHS policies and procedure.</p>
                                <p style="margin: 0 0 6px 0; line-height: 1.4;"><strong>13.</strong> Please check PO details thoroughly, and in case of any query, please raise your concerns immediately.</p>
                            </div>
                        </div>

                        <div class="footer" style="font-family: 'Arial', sans-serif;">
                            <t t-if="page == topage and o.state != 'purchase'">
                                <div style="text-align: center; margin: 20px 0; white-space: nowrap;">
                                    <span style="display: inline-block; width: 100px; text-align: center; margin: 0 25px; font-size: 11px; border-top: 1px solid black; padding-top: 3px;">Prepared By</span>
                                    <span style="display: inline-block; width: 100px; text-align: center; margin: 0 25px; font-size: 11px; border-top: 1px solid black; padding-top: 3px;">Checked By</span>
                                    <span style="display: inline-block; width: 100px; text-align: center; margin: 0 25px; font-size: 11px; border-top: 1px solid black; padding-top: 3px;">Approved By</span>
                                </div>
                            </t>
                            <div class="row" style="font-size: 11px; text-align: right;">
                                <div class="col-12 text-right">Page <span class="page"/> of <span class="topage"/></div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

